    "dotenv": "^17.3.1",
    "electron": "^41.1.0",
    "electron-log": "^4.4.1",
    "get-port": "^7.2.0",
    "wait-on": "^9.0.4"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  }
